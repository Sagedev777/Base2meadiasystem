# ─────────────────────────────────────────────────
# Base 2 Media Academy — Backend Environment Config
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Database ────────────────────────────────────
# Local XAMPP (socket-based)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=base2media_sms

# XAMPP MySQL socket path (Linux)
# DB_SOCKET=/opt/lampp/var/mysql/mysql.sock

# cPanel MySQL (TCP-based)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=cpanelusername_dbuser
# DB_PASSWORD=your_db_password
# DB_NAME=cpanelusername_base2media

# ── JWT Auth ─────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Server ───────────────────────────────────────
PORT=4000
NODE_ENV=development

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP ─────────────────────────────────
# For Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here

# For cPanel Email:
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@base2media.ac
# SMTP_PASS=your_cpanel_email_password

# ── App URL (for password reset links) ──────────
APP_URL=http://localhost:5173
